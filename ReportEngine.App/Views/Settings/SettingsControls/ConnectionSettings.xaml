<UserControl
    x:Class="ReportEngine.App.Views.Settings.SettingsControls.ConnectionSettings"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid Margin="20">

        <Border
            Padding="25"
            Background="{DynamicResource PrimaryColor}"
            BorderBrush="{DynamicResource SecondaryColor}"
            BorderThickness="1"
            CornerRadius="8">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!--  Заголовок  -->
                <TextBlock
                    Grid.Row="0"
                    Grid.ColumnSpan="2"
                    Margin="0,0,0,10"
                    FontSize="18"
                    FontWeight="SemiBold"
                    Text="Настройки подключения" />

                <!--  Сервер  -->
                <TextBlock
                    Grid.Row="2"
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Text="Сервер:" />

                <TextBox
                    Grid.Row="2"
                    Grid.Column="1"
                    Height="34"
                    Margin="0,4"
                    Text="{Binding ServerAddress}" />

                <!--  Порт  -->
                <TextBlock
                    Grid.Row="3"
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Text="Порт:" />

                <TextBox
                    Grid.Row="3"
                    Grid.Column="1"
                    Height="34"
                    Margin="0,4"
                    Text="{Binding ServerPort}" />

                <!--  Имя БД  -->
                <TextBlock
                    Grid.Row="4"
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Text="База данных:" />

                <TextBox
                    Grid.Row="4"
                    Grid.Column="1"
                    Height="34"
                    Margin="0,4"
                    Text="{Binding DbName}" />

                <!--  Пользователь  -->
                <TextBlock
                    Grid.Row="5"
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Text="Пользователь:" />

                <TextBox
                    Grid.Row="5"
                    Grid.Column="1"
                    Height="34"
                    Margin="0,4"
                    Text="{Binding DbUser}" />

                <!--  Пароль  -->
                <TextBlock
                    Grid.Row="6"
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    Text="Пароль:" />

                <PasswordBox
                    Grid.Row="6"
                    Grid.Column="1"
                    Height="34"
                    Margin="0,4"
                    PasswordChanged="PasswordBox_PasswordChanged" />
            </Grid>

        </Border>

    </Grid>
</UserControl>