<UserControl
    FontSize="16"
    HorizontalAlignment="Stretch"
    HorizontalContentAlignment="Stretch"
    VerticalAlignment="Stretch"
    Width="Auto"
    x:Class="ReportEngine.App.Views.Controls.ProjectCardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer
        HorizontalAlignment="Stretch"
        HorizontalScrollBarVisibility="Disabled"
        Margin="10"
        VerticalAlignment="Stretch"
        VerticalScrollBarVisibility="Auto">

        <Grid HorizontalAlignment="Stretch" VerticalAlignment="Top">

            <!--  Сетка 2x3  -->
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <GroupBox
                BorderThickness="0"
                Grid.Column="0"
                Grid.Row="0"
                Header="Основная информация"
                Margin="0,0,0,10"
                MinWidth="320">

                <Grid Margin="10">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="0.75*" />
                        <ColumnDefinition Width="2*" />
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>


                    <!--  №  -->
                    <TextBlock Margin="5" Text="№ п/п:" />

                    <TextBox
                        Grid.Column="1"
                        Margin="5"
                        Text="{Binding CurrentProjectModel.Number}" />


                    <!--  Обозначение  -->
                    <TextBlock
                        Grid.Row="1"
                        Margin="5"
                        Text="Обозначение КД:" />

                    <TextBox
                        Grid.Column="1"
                        Grid.Row="1"
                        Margin="5"
                        MinWidth="300"
                        Text="{Binding CurrentProjectModel.Description}" />


                    <!--  Дата  -->
                    <TextBlock
                        Grid.Row="2"
                        Margin="5"
                        Text="Дата запроса:" />

                    <DatePicker
                        Grid.Column="1"
                        Grid.Row="2"
                        HorizontalAlignment="Left"
                        Margin="5"
                        MaxWidth="150"
                        SelectedDate="{Binding CurrentProjectModel.CreationDate}" />


                    <!--  Заказчик  -->
                    <TextBlock
                        Grid.Row="3"
                        Margin="5"
                        Text="Заказчик:" />

                    <Grid Grid.Column="1" Grid.Row="3">

                        <Grid.ColumnDefinitions>

                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />

                        </Grid.ColumnDefinitions>

                        <TextBox
                            Grid.Column="0"
                            Margin="5"
                            Text="{Binding CurrentProjectModel.Company}" />

                        <Button
                            Command="{Binding ProjectCommandProvider.ShowCompanyDialogCommand}"
                            Content="..."
                            Grid.Column="1"
                            Height="28"
                            Margin="5"
                            Width="28" />

                    </Grid>


                    <!--  Объект  -->
                    <TextBlock
                        Grid.Row="4"
                        Margin="5"
                        Text="Объект:" />

                    <Grid Grid.Column="1" Grid.Row="4">

                        <Grid.ColumnDefinitions>

                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />

                        </Grid.ColumnDefinitions>

                        <TextBox
                            Grid.Column="0"
                            Margin="5"
                            Text="{Binding CurrentProjectModel.Object}" />

                        <Button
                            Command="{Binding ProjectCommandProvider.ShowSubjectDialogCommand}"
                            Content="..."
                            Grid.Column="1"
                            Height="28"
                            Margin="5"
                            Width="28" />

                    </Grid>


                </Grid>

            </GroupBox>

            <GroupBox
                BorderThickness="0"
                Grid.Column="2"
                Grid.Row="0"
                Header="Сроки проекта"
                Margin="0,0,0,10"
                MinWidth="600">

                <Grid Margin="10">

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="40" />
                        <RowDefinition Height="40" />
                        <RowDefinition Height="40" />
                    </Grid.RowDefinitions>


                    <TextBlock Margin="5" Text="Старт проекта" />

                    <DatePicker
                        Grid.Column="1"
                        HorizontalAlignment="Left"
                        Margin="5"
                        MaxWidth="150"
                        SelectedDate="{Binding CurrentProjectModel.StartDate}" />


                    <TextBlock
                        Grid.Row="1"
                        Margin="5"
                        Text="Выход из производства" />

                    <DatePicker
                        Grid.Column="1"
                        Grid.Row="1"
                        HorizontalAlignment="Left"
                        Margin="5"
                        MaxWidth="150"
                        SelectedDate="{Binding CurrentProjectModel.OutOfProduction}" />


                    <TextBlock
                        Grid.Row="2"
                        Margin="5"
                        Text="Дата окончания договора" />

                    <DatePicker
                        Grid.Column="1"
                        Grid.Row="2"
                        HorizontalAlignment="Left"
                        Margin="5"
                        MaxWidth="150"
                        SelectedDate="{Binding CurrentProjectModel.EndDate}" />

                </Grid>

            </GroupBox>

            <GroupBox
                BorderThickness="0"
                Grid.Column="0"
                Grid.Row="1"
                Header="Производство"
                Margin="0,0,0,10">

                <Grid Margin="10">

                    <Grid.ColumnDefinitions>

                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="*" />

                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                        <RowDefinition />
                    </Grid.RowDefinitions>

                    <TextBlock
                        Grid.Row="0"
                        Margin="5"
                        Text="Заказ покупателя:" />

                    <TextBox
                        Grid.Column="1"
                        Grid.Row="0"
                        Margin="5"
                        Text="{Binding CurrentProjectModel.OrderCustomer}" />

                    <TextBlock
                        Grid.Row="1"
                        Margin="5"
                        Text="Заявка на производство:" />

                    <TextBox
                        Grid.Column="1"
                        Grid.Row="1"
                        Margin="5"
                        Text="{Binding CurrentProjectModel.RequestProduction}" />


                    <TextBlock
                        Grid.Row="2"
                        Margin="5"
                        Text="Кол-во стендов (шт.):" />

                    <TextBox
                        Grid.Column="1"
                        Grid.Row="2"
                        Margin="5"
                        Text="{Binding CurrentProjectModel.StandCount}" />


                    <TextBlock
                        Grid.Row="3"
                        Margin="5"
                        Text="Стоимость (руб.):" />

                    <TextBox
                        Grid.Column="1"
                        Grid.Row="3"
                        Margin="5"
                        Text="{Binding CurrentProjectModel.Cost}" />


                    <TextBlock
                        Grid.Row="4"
                        Margin="5"
                        Text="Трудозатраты (чел/час):" />

                    <TextBox
                        Grid.Column="1"
                        Grid.Row="4"
                        Margin="5"
                        Text="{Binding CurrentProjectModel.HumanCost}" />


                    <CheckBox
                        Content="Оцинкование стендов"
                        Grid.ColumnSpan="2"
                        Grid.Row="5"
                        IsChecked="{Binding CurrentProjectModel.IsGalvanized}"
                        Margin="5" />

                </Grid>

            </GroupBox>

            <GroupBox
                BorderThickness="0"
                Grid.Column="2"
                Grid.Row="1"
                Header="Управление"
                Margin="0,0,0,10">

                <Grid Margin="10">

                    <Grid.ColumnDefinitions>

                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="*" />

                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>

                        <RowDefinition Height="50" />
                        <RowDefinition Height="40" />

                    </Grid.RowDefinitions>


                    <TextBlock Margin="5" Text="Статус" />

                    <ComboBox
                        Grid.Column="1"
                        Grid.ColumnSpan="2"
                        ItemsSource="{Binding CurrentProjectModel.Statuses}"
                        Margin="5"
                        SelectedItem="{Binding CurrentProjectModel.Status}" />


                    <TextBlock
                        Grid.Row="1"
                        Margin="5"
                        Text="Руководитель" />

                    <TextBox
                        Grid.Column="1"
                        Grid.Row="1"
                        Margin="5"
                        Text="{Binding CurrentProjectModel.Manager}" />
                </Grid>
            </GroupBox>

            <GroupBox
                BorderThickness="0"
                Grid.Column="0"
                Grid.ColumnSpan="3"
                Grid.Row="2"
                Header="Маркировка">

                <Grid Margin="10">

                    <Grid.ColumnDefinitions>

                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="*" />

                        <ColumnDefinition Width="180" />
                        <ColumnDefinition Width="*" />

                    </Grid.ColumnDefinitions>


                    <TextBlock Margin="5" Text="Маркировка +:" />

                    <TextBox
                        Grid.Column="1"
                        Margin="5"
                        Text="{Binding CurrentProjectModel.MarkPlus}" />


                    <TextBlock
                        Grid.Column="2"
                        Margin="5"
                        Text="Маркировка -:" />

                    <TextBox
                        Grid.Column="3"
                        Margin="5"
                        Text="{Binding CurrentProjectModel.MarkMinus}" />
                </Grid>
            </GroupBox>

            <StackPanel
                Grid.Column="2"
                Grid.Row="3"
                Height="35"
                HorizontalAlignment="Right"
                Margin="5,15,5,5"
                Orientation="Horizontal">

                <Button
                    Command="{Binding ProjectCommandProvider.CreateNewCardCommand}"
                    Content="Добавить новый"
                    Margin="0,0,10,0"
                    Width="150" />

                <Button
                    Command="{Binding ProjectCommandProvider.SaveChangesCommand}"
                    Content="Сохранить изменения"
                    Width="200" />

            </StackPanel>

        </Grid>
    </ScrollViewer>
</UserControl>