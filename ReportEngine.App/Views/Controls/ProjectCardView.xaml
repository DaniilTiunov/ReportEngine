<UserControl
    x:Class="ReportEngine.App.Views.Controls.ProjectCardView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch"
    FontSize="16">

    <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <Grid.ColumnDefinitions>
            <ColumnDefinition MinWidth="950" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <ScrollViewer
            Grid.ColumnSpan="2"
            VerticalAlignment="Stretch"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">

            <Grid
                Margin="0"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch">

                <!--  Сетка 2x3  -->
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="7" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <GroupBox
                    Grid.Row="0"
                    Grid.Column="0"
                    MinWidth="320"
                    Margin="0,0,0,10"
                    BorderThickness="0"
                    Header="Основная информация">

                    <Grid Margin="10">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="0.75*" />
                            <ColumnDefinition Width="2*" />
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>


                        <!--  №  -->
                        <TextBlock Margin="5" Text="№ п/п:" />

                        <TextBox
                            Grid.Column="1"
                            Margin="5"
                            Text="{Binding CurrentProjectModel.Number}" />


                        <!--  Обозначение  -->
                        <TextBlock
                            Grid.Row="1"
                            Margin="5"
                            Text="Обозначение КД:" />

                        <TextBox
                            Grid.Row="1"
                            Grid.Column="1"
                            MinWidth="300"
                            Margin="5"
                            Text="{Binding CurrentProjectModel.Description}" />


                        <!--  Дата  -->
                        <TextBlock
                            Grid.Row="2"
                            Margin="5"
                            Text="Дата запроса:" />

                        <DatePicker
                            Grid.Row="2"
                            Grid.Column="1"
                            MaxWidth="150"
                            Margin="5"
                            HorizontalAlignment="Left"
                            SelectedDate="{Binding CurrentProjectModel.CreationDate}" />


                        <!--  Заказчик  -->
                        <TextBlock
                            Grid.Row="3"
                            Margin="5"
                            Text="Заказчик:" />

                        <Grid Grid.Row="3" Grid.Column="1">

                            <Grid.ColumnDefinitions>

                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />

                            </Grid.ColumnDefinitions>

                            <TextBox
                                Grid.Column="0"
                                Margin="5"
                                Text="{Binding CurrentProjectModel.Company}" />

                            <Button
                                Grid.Column="1"
                                Width="28"
                                Height="28"
                                Margin="5"
                                Command="{Binding ProjectCommandProvider.ShowCompanyDialogCommand}"
                                Content="..." />

                        </Grid>


                        <!--  Объект  -->
                        <TextBlock
                            Grid.Row="4"
                            Margin="5"
                            Text="Объект:" />

                        <Grid Grid.Row="4" Grid.Column="1">

                            <Grid.ColumnDefinitions>

                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />

                            </Grid.ColumnDefinitions>

                            <TextBox
                                Grid.Column="0"
                                Margin="5"
                                Text="{Binding CurrentProjectModel.Object}" />

                            <Button
                                Grid.Column="1"
                                Width="28"
                                Height="28"
                                Margin="5"
                                Command="{Binding ProjectCommandProvider.ShowSubjectDialogCommand}"
                                Content="..." />

                        </Grid>


                    </Grid>

                </GroupBox>

                <GroupBox
                    Grid.Row="0"
                    Grid.Column="2"
                    MinWidth="600"
                    Margin="0,0,0,10"
                    BorderThickness="0"
                    Header="Сроки проекта">

                    <Grid Margin="10">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition Height="40" />
                            <RowDefinition Height="40" />
                            <RowDefinition Height="40" />
                        </Grid.RowDefinitions>


                        <TextBlock Margin="5" Text="Старт проекта" />

                        <DatePicker
                            Grid.Column="1"
                            MaxWidth="150"
                            Margin="5"
                            HorizontalAlignment="Left"
                            SelectedDate="{Binding CurrentProjectModel.StartDate}" />


                        <TextBlock
                            Grid.Row="1"
                            Margin="5"
                            Text="Выход из производства" />

                        <DatePicker
                            Grid.Row="1"
                            Grid.Column="1"
                            MaxWidth="150"
                            Margin="5"
                            HorizontalAlignment="Left"
                            SelectedDate="{Binding CurrentProjectModel.OutOfProduction}" />


                        <TextBlock
                            Grid.Row="2"
                            Margin="5"
                            Text="Дата окончания договора" />

                        <DatePicker
                            Grid.Row="2"
                            Grid.Column="1"
                            MaxWidth="150"
                            Margin="5"
                            HorizontalAlignment="Left"
                            SelectedDate="{Binding CurrentProjectModel.EndDate}" />

                    </Grid>

                </GroupBox>

                <GroupBox
                    Grid.Row="1"
                    Grid.Column="0"
                    Margin="0,0,0,10"
                    BorderThickness="0"
                    Header="Производство">

                    <Grid Margin="10">

                        <Grid.ColumnDefinitions>

                            <ColumnDefinition Width="200" />
                            <ColumnDefinition Width="*" />

                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                            <RowDefinition />
                        </Grid.RowDefinitions>

                        <TextBlock
                            Grid.Row="0"
                            Margin="5"
                            Text="Заказ покупателя:" />

                        <TextBox
                            Grid.Row="0"
                            Grid.Column="1"
                            Margin="5"
                            Text="{Binding CurrentProjectModel.OrderCustomer}" />

                        <TextBlock
                            Grid.Row="1"
                            Margin="5"
                            Text="Заявка на производство:" />

                        <TextBox
                            Grid.Row="1"
                            Grid.Column="1"
                            Margin="5"
                            Text="{Binding CurrentProjectModel.RequestProduction}" />


                        <TextBlock
                            Grid.Row="2"
                            Margin="5"
                            Text="Кол-во стендов (шт.):" />

                        <TextBox
                            Grid.Row="2"
                            Grid.Column="1"
                            Margin="5"
                            Text="{Binding CurrentProjectModel.StandCount}" />


                        <TextBlock
                            Grid.Row="3"
                            Margin="5"
                            Text="Стоимость (руб.):" />

                        <TextBox
                            Grid.Row="3"
                            Grid.Column="1"
                            Margin="5"
                            Text="{Binding CurrentProjectModel.Cost}" />


                        <TextBlock
                            Grid.Row="4"
                            Margin="5"
                            Text="Трудозатраты (чел/час):" />

                        <TextBox
                            Grid.Row="4"
                            Grid.Column="1"
                            Margin="5"
                            Text="{Binding CurrentProjectModel.HumanCost}" />


                        <CheckBox
                            Grid.Row="5"
                            Grid.ColumnSpan="2"
                            Margin="5"
                            Content="Оцинкование стендов"
                            IsChecked="{Binding CurrentProjectModel.IsGalvanized}" />

                    </Grid>

                </GroupBox>

                <GroupBox
                    Grid.Row="1"
                    Grid.Column="2"
                    Margin="0,0,0,10"
                    BorderThickness="0"
                    Header="Управление">

                    <Grid Margin="10">

                        <Grid.ColumnDefinitions>

                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="*" />

                        </Grid.ColumnDefinitions>

                        <Grid.RowDefinitions>

                            <RowDefinition Height="50" />
                            <RowDefinition Height="40" />

                        </Grid.RowDefinitions>


                        <TextBlock Margin="5" Text="Статус" />

                        <ComboBox
                            Grid.Column="1"
                            Grid.ColumnSpan="2"
                            Margin="5"
                            ItemsSource="{Binding CurrentProjectModel.Statuses}"
                            SelectedItem="{Binding CurrentProjectModel.Status}" />


                        <TextBlock
                            Grid.Row="1"
                            Margin="5"
                            Text="Руководитель" />

                        <TextBox
                            Grid.Row="1"
                            Grid.Column="1"
                            Margin="5"
                            Text="{Binding CurrentProjectModel.Manager}" />
                    </Grid>
                </GroupBox>

                <GroupBox
                    Grid.Row="2"
                    Grid.Column="0"
                    Grid.ColumnSpan="3"
                    BorderThickness="0"
                    Header="Маркировка">

                    <Grid Margin="10">

                        <Grid.ColumnDefinitions>

                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="*" />

                            <ColumnDefinition Width="180" />
                            <ColumnDefinition Width="*" />

                        </Grid.ColumnDefinitions>


                        <TextBlock Margin="5" Text="Маркировка +:" />

                        <TextBox
                            Grid.Column="1"
                            Margin="5"
                            Text="{Binding CurrentProjectModel.MarkPlus}" />


                        <TextBlock
                            Grid.Column="2"
                            Margin="5"
                            Text="Маркировка -:" />

                        <TextBox
                            Grid.Column="3"
                            Margin="5"
                            Text="{Binding CurrentProjectModel.MarkMinus}" />
                    </Grid>
                </GroupBox>

                <StackPanel
                    Grid.Row="3"
                    Grid.Column="2"
                    Height="35"
                    Margin="5,15,5,5"
                    HorizontalAlignment="Right"
                    Orientation="Horizontal">

                    <Button
                        Width="150"
                        Margin="0,0,10,0"
                        Command="{Binding ProjectCommandProvider.CreateNewCardCommand}"
                        Content="Добавить новый" />

                    <Button
                        Width="200"
                        Command="{Binding ProjectCommandProvider.SaveChangesCommand}"
                        Content="Сохранить изменения" />

                </StackPanel>

            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
