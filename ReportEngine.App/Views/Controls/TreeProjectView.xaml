<UserControl
    Background="{DynamicResource PrimaryColor}"
    FontSize="14"
    Foreground="{DynamicResource PrimaryForeground}"
    mc:Ignorable="d"
    x:Class="ReportEngine.App.Views.Controls.TreeProjectView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:avalonDock="https://github.com/Dirkster99/AvalonDock"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Resources/Dictionaries/Styles/GigaChadUI.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="2" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <avalonDock:DockingManager Grid.Column="0">
            <avalonDock:LayoutRoot>
                <avalonDock:LayoutPanel Orientation="Vertical" x:Name="LayoutPanel">
                    <avalonDock:LayoutAnchorablePane DockHeight="*">
                        <avalonDock:LayoutAnchorable
                            CanClose="False"
                            CanHide="False"
                            Title=" Навигация по проекту">


                            <!--  Первое дерево  -->
                            <TreeView FontSize="14" x:Name="NavigationTree">

                                <TreeViewItem Header="Проект" IsExpanded="True">
                                    <TreeViewItem
                                        Header="Карточка проекта"
                                        MouseDoubleClick="OpenCurrentView"
                                        Tag="ProjectCard" />

                                    <TreeViewItem Header="Редактирование стенда" IsExpanded="True">
                                        <TreeViewItem
                                            Header="Расчёт стенда"
                                            MouseDoubleClick="OpenCurrentView"
                                            Tag="ProjectPreview" />
                                        <TreeViewItem
                                            Header="Формирование упаковки"
                                            MouseDoubleClick="OpenCurrentView"
                                            Tag="StandsContainer" />
                                        <TreeViewItem
                                            Header="Предпросмотр документов"
                                            MouseDoubleClick="OpenCurrentView"
                                            Tag="DockViewer" />
                                    </TreeViewItem>
                                </TreeViewItem>

                                <TreeViewItem Header="Расчёт проекта" IsExpanded="True">
                                    <TreeViewItem Header="Рассчитать проект" Tag="CalculateProject">
                                        <TreeViewItem.InputBindings>
                                            <MouseBinding Command="{Binding CalculateProjectCommandAsync}"
                                                          Gesture="LeftDoubleClick" />
                                        </TreeViewItem.InputBindings>
                                    </TreeViewItem>

                                    <TreeViewItem Header="Пересчёт" Tag="CalculateProject">
                                        <TreeViewItem.InputBindings>
                                            <MouseBinding Command="{Binding RecalculateProjectCommandAsync}"
                                                          Gesture="LeftDoubleClick" />
                                        </TreeViewItem.InputBindings>
                                    </TreeViewItem>
                                </TreeViewItem>

                                <TreeViewItem Header="Отчёты" IsExpanded="True">
                                    <TreeViewItem Header="Сводная ведомость" Tag="SummaryReport">
                                        <TreeViewItem.InputBindings>
                                            <MouseBinding Command="{Binding CreateSummaryReportAsync}"
                                                          Gesture="LeftDoubleClick" />
                                        </TreeViewItem.InputBindings>
                                    </TreeViewItem>

                                    <TreeViewItem Header="Ведомость комплектующих" Tag="ComponentsList">
                                        <TreeViewItem.InputBindings>
                                            <MouseBinding Command="{Binding CreateComponentsListReportAsync}"
                                                          Gesture="LeftDoubleClick" />
                                        </TreeViewItem.InputBindings>
                                    </TreeViewItem>

                                    <TreeViewItem Header="Шильдики и таблички" Tag="NamePlates">
                                        <TreeViewItem.InputBindings>
                                            <MouseBinding Command="{Binding CreateNamePlatesReportAsync}"
                                                          Gesture="LeftDoubleClick" />
                                        </TreeViewItem.InputBindings>
                                    </TreeViewItem>

                                    <TreeViewItem Header="Маркировка" Tag="MarksReport">
                                        <TreeViewItem.InputBindings>
                                            <MouseBinding Command="{Binding CreateMarksReportReportAsync}"
                                                          Gesture="LeftDoubleClick" />
                                        </TreeViewItem.InputBindings>
                                    </TreeViewItem>

                                    <TreeViewItem Header="Производство" Tag="ProductionList">
                                        <TreeViewItem.InputBindings>
                                            <MouseBinding Command="{Binding CreateProductionListReportAsync}"
                                                          Gesture="LeftDoubleClick" />
                                        </TreeViewItem.InputBindings>
                                    </TreeViewItem>

                                    <TreeViewItem Header="Фин. план" Tag="FinPlan">
                                        <TreeViewItem.InputBindings>
                                            <MouseBinding Command="{Binding CreateFinPlanReportAsync}"
                                                          Gesture="LeftDoubleClick" />
                                        </TreeViewItem.InputBindings>
                                    </TreeViewItem>

                                    <TreeViewItem Header="Отчёт тара" Tag="ContainersReport">
                                        <TreeViewItem.InputBindings>
                                            <MouseBinding Command="{Binding CreateContainersReportReportAsync}"
                                                          Gesture="LeftDoubleClick" />
                                        </TreeViewItem.InputBindings>
                                    </TreeViewItem>

                                    <TreeViewItem Header="Паспорт" Tag="Passport">
                                        <TreeViewItem.InputBindings>
                                            <MouseBinding Command="{Binding CreatePassportReportAsync}"
                                                          Gesture="LeftDoubleClick" />
                                        </TreeViewItem.InputBindings>
                                    </TreeViewItem>

                                    <TreeViewItem Header="Технологические карты" Tag="TechCards">
                                        <TreeViewItem.InputBindings>
                                            <MouseBinding Command="{Binding CreateTechCardsReportAsync}"
                                                          Gesture="LeftDoubleClick" />
                                        </TreeViewItem.InputBindings>
                                    </TreeViewItem>
                                </TreeViewItem>
                            </TreeView>

                        </avalonDock:LayoutAnchorable>
                    </avalonDock:LayoutAnchorablePane>
                </avalonDock:LayoutPanel>
            </avalonDock:LayoutRoot>
        </avalonDock:DockingManager>

        <GridSplitter
            Background="{DynamicResource SecondaryColor}"
            Grid.Column="1"
            HorizontalAlignment="Stretch"
            Width="2" />


        <TabControl Grid.Column="2" x:Name="MainTabControl">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="VerticalContentAlignment" Value="Stretch" />
                </Style>
            </TabControl.Resources>
        </TabControl>
    </Grid>
</UserControl>