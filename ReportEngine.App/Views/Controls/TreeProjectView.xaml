<UserControl
    x:Class="ReportEngine.App.Views.Controls.TreeProjectView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:avalonDock="https://github.com/Dirkster99/AvalonDock"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dragablz="clr-namespace:Dragablz;assembly=Dragablz"
    xmlns:localDisplay="clr-namespace:ReportEngine.App.Display"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{DynamicResource PrimaryColor}"
    FontSize="14"
    Foreground="{DynamicResource PrimaryForeground}"
    mc:Ignorable="d">

    <UserControl.Resources>
        <localDisplay:DefaultInterTabClient x:Key="DefaultInterTabClient" />
        <dragablz:InterTabController x:Key="InterTabController" InterTabClient="{StaticResource DefaultInterTabClient}" />
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <avalonDock:DockingManager>
            <avalonDock:LayoutRoot>
                <avalonDock:LayoutPanel x:Name="LayoutPanel" Orientation="Vertical">
                    <avalonDock:LayoutAnchorablePane DockHeight="900">
                        <avalonDock:LayoutAnchorable
                            Title="Навигация по проекту"
                            CanClose="False"
                            CanHide="False">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="0.25*" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <!--  Первое дерево  -->
                                <TreeView
                                    x:Name="MainTree"
                                    Grid.Row="0"
                                    MinWidth="200"
                                    FontSize="14"
                                    MouseDoubleClick="OpenCurrentView">
                                    <TreeViewItem Header="Проект" IsExpanded="True">
                                        <TreeViewItem
                                            x:Name="ProjectCard"
                                            Margin="0,3,0,3"
                                            Header="Карточка проекта"
                                            Tag="ProjectCard" />
                                        <TreeViewItem Header="Редактирование стенда" IsExpanded="True">
                                            <TreeViewItem
                                                Margin="0,3,10,3"
                                                Header="Расчёт стенда"
                                                Tag="ProjectPreview" />
                                            <TreeViewItem
                                                Margin="0,3,0,3"
                                                Header="Формирование упаковки"
                                                Tag="StandsContainer" />
                                        </TreeViewItem>
                                    </TreeViewItem>
                                </TreeView>

                                <!--  Второе дерево  -->
                                <TreeView
                                    x:Name="ReportTree"
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    MinHeight="500"
                                    FontSize="14"
                                    MouseDoubleClick="ReportTree_MouseDoubleClick">
                                    <TreeViewItem Header="Создание отчётов и расчёт" IsExpanded="True">
                                        <TreeViewItem
                                            Margin="0,3,0,3"
                                            Header="Расчитать проект"
                                            Tag="CalculateProject" />
                                        <TreeViewItem
                                            Margin="0,3,0,3"
                                            Header="Переформировать комплектущие"
                                            Tag="UpdateAllProps" />
                                        <TreeViewItem
                                            Margin="0,3,0,3"
                                            Header="Сводная ведомость"
                                            Tag="SummaryReport" />
                                        <TreeViewItem
                                            Margin="0,3,0,3"
                                            Header="Ведомость комплектующих"
                                            Tag="ComponentsList" />
                                        <TreeViewItem
                                            Margin="0,3,0,3"
                                            Header="Шильдики и таблички"
                                            Tag="NamePlates" />
                                        <TreeViewItem
                                            Margin="0,3,0,3"
                                            Header="Маркировка"
                                            Tag="MarksReport" />
                                        <TreeViewItem
                                            Margin="0,3,0,3"
                                            Header="Производство"
                                            Tag="ProductionList" />
                                        <TreeViewItem
                                            Margin="0,3,0,3"
                                            Header="Фин. план"
                                            Tag="FinPlan" />
                                        <TreeViewItem
                                            Margin="0,3,0,3"
                                            Header="Отчёт тара"
                                            Tag="ContainersReport" />
                                        <TreeViewItem
                                            Margin="0,3,0,3"
                                            Header="Паспорт"
                                            Tag="Passport" />
                                        <TreeViewItem
                                            Margin="0,3,0,3"
                                            Header="Технологические карты"
                                            Tag="TechCards" />
                                    </TreeViewItem>
                                </TreeView>
                            </Grid>
                        </avalonDock:LayoutAnchorable>
                    </avalonDock:LayoutAnchorablePane>
                </avalonDock:LayoutPanel>
            </avalonDock:LayoutRoot>
        </avalonDock:DockingManager>

        <GridSplitter
            Grid.Column="1"
            Width="2"
            HorizontalAlignment="Stretch"
            Background="WhiteSmoke" />

        <dragablz:TabablzControl
            x:Name="MainTabControl"
            Grid.Column="2"
            ConsolidateOrphanedItems="True"
            InterTabController="{StaticResource InterTabController}"
            ShowDefaultCloseButton="True" />
    </Grid>
</UserControl>

