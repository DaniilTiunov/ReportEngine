<UserControl
    x:Class="ReportEngine.App.Views.Controls.TreeProjectView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:avalonDock="https://github.com/Dirkster99/AvalonDock"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:localDisplay="clr-namespace:ReportEngine.App.Display"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{DynamicResource PrimaryColor}"
    FontSize="14"
    Foreground="{DynamicResource PrimaryForeground}"
    mc:Ignorable="d">

    <UserControl.Resources>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="2" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <avalonDock:DockingManager>
            <avalonDock:LayoutRoot>
                <avalonDock:LayoutPanel x:Name="LayoutPanel" Orientation="Vertical">
                    <avalonDock:LayoutAnchorablePane DockHeight="*">
                        <avalonDock:LayoutAnchorable
                            Title=" Навигация по проекту"
                            CanClose="False"
                            CanHide="False">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="0.25*" />
                                    <RowDefinition Height="0.25*" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <!--  Первое дерево  -->
                                <TreeView
                                    x:Name="MainTree"
                                    Grid.Row="0"
                                    MinWidth="200"
                                    FontSize="14"
                                    Foreground="{DynamicResource PrimaryForeground}"
                                    MouseDoubleClick="OpenCurrentView">
                                    <TreeViewItem
                                        Foreground="{DynamicResource PrimaryForeground}"
                                        Header="Проект"
                                        IsExpanded="True">
                                        <TreeViewItem
                                            x:Name="ProjectCard"
                                            Margin="0,3,0,3"
                                            Foreground="{DynamicResource PrimaryForeground}"
                                            Header="Карточка проекта"
                                            Tag="ProjectCard" />
                                        <TreeViewItem
                                            Foreground="{DynamicResource PrimaryForeground}"
                                            Header="Редактирование стенда"
                                            IsExpanded="True">
                                            <TreeViewItem
                                                Margin="0,3,10,3"
                                                Foreground="{DynamicResource PrimaryForeground}"
                                                Header="Расчёт стенда"
                                                Tag="ProjectPreview" />
                                            <TreeViewItem
                                                Margin="0,3,0,3"
                                                Foreground="{DynamicResource PrimaryForeground}"
                                                Header="Формирование упаковки"
                                                Tag="StandsContainer" />
                                            <TreeViewItem
                                                Margin="0,3,0,3"
                                                Foreground="{DynamicResource PrimaryForeground}"
                                                Header="Предпросмотр документов"
                                                Tag="DockViewer" />
                                        </TreeViewItem>
                                    </TreeViewItem>
                                </TreeView>

                                <TreeView
                                    x:Name="CalculateTree"
                                    Grid.Row="1"
                                    Grid.Column="1"
                                    FontSize="14"
                                    Foreground="{DynamicResource PrimaryForeground}"
                                    MouseDoubleClick="CalculateTree_MouseDoubleClick">
                                    <TreeViewItem
                                        Foreground="{DynamicResource PrimaryForeground}"
                                        Header="Расчёт проекта"
                                        IsExpanded="True">
                                        <TreeViewItem
                                            Margin="0,3,0,3"
                                            Foreground="{DynamicResource PrimaryForeground}"
                                            Header="Расчитать проект"
                                            Tag="CalculateProject" />
                                        <TreeViewItem
                                            Margin="0,3,0,3"
                                            Foreground="{DynamicResource PrimaryForeground}"
                                            Header="Перерасчёт"
                                            Tag="UpdateAllProps" />
                                    </TreeViewItem>
                                </TreeView>

                                <!--  Третье дерево  -->
                                <TreeView
                                    x:Name="ReportTree"
                                    Grid.Row="2"
                                    Grid.Column="1"
                                    FontSize="14"
                                    Foreground="{DynamicResource PrimaryForeground}"
                                    MouseDoubleClick="ReportTree_MouseDoubleClick">
                                    <TreeViewItem
                                        Foreground="{DynamicResource PrimaryForeground}"
                                        Header="Создание отчётов для проекта"
                                        IsExpanded="True">
                                        <TreeViewItem
                                            Margin="0,3,0,3"
                                            Foreground="{DynamicResource PrimaryForeground}"
                                            Header="Сводная ведомость"
                                            Tag="SummaryReport" />
                                        <TreeViewItem
                                            Margin="0,3,0,3"
                                            Foreground="{DynamicResource PrimaryForeground}"
                                            Header="Ведомость комплектующих"
                                            Tag="ComponentsList" />
                                        <TreeViewItem
                                            Margin="0,3,0,3"
                                            Foreground="{DynamicResource PrimaryForeground}"
                                            Header="Шильдики и таблички"
                                            Tag="NamePlates" />
                                        <TreeViewItem
                                            Margin="0,3,0,3"
                                            Foreground="{DynamicResource PrimaryForeground}"
                                            Header="Маркировка"
                                            Tag="MarksReport" />
                                        <TreeViewItem
                                            Margin="0,3,0,3"
                                            Foreground="{DynamicResource PrimaryForeground}"
                                            Header="Производство"
                                            Tag="ProductionList" />
                                        <TreeViewItem
                                            Margin="0,3,0,3"
                                            Foreground="{DynamicResource PrimaryForeground}"
                                            Header="Фин. план"
                                            Tag="FinPlan" />
                                        <TreeViewItem
                                            Margin="0,3,0,3"
                                            Foreground="{DynamicResource PrimaryForeground}"
                                            Header="Отчёт тара"
                                            Tag="ContainersReport" />
                                        <TreeViewItem
                                            Margin="0,3,0,3"
                                            Foreground="{DynamicResource PrimaryForeground}"
                                            Header="Паспорт"
                                            Tag="Passport" />
                                        <TreeViewItem
                                            Margin="0,3,0,3"
                                            Foreground="{DynamicResource PrimaryForeground}"
                                            Header="Технологические карты"
                                            Tag="TechCards" />
                                    </TreeViewItem>
                                </TreeView>
                            </Grid>
                        </avalonDock:LayoutAnchorable>
                    </avalonDock:LayoutAnchorablePane>
                </avalonDock:LayoutPanel>
            </avalonDock:LayoutRoot>
        </avalonDock:DockingManager>

        <GridSplitter
            Grid.Column="1"
            Width="2"
            HorizontalAlignment="Stretch"
            Background="{DynamicResource SecondaryColor}" />


        <TabControl x:Name="MainTabControl" Grid.Column="2" />
    </Grid>
</UserControl>