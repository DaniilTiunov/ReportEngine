<UserControl
    x:Class="ReportEngine.App.Views.Controls.DockViewerView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Spreadsheet="clr-namespace:Syncfusion.UI.Xaml.Spreadsheet;assembly=Syncfusion.SfSpreadsheet.WPF"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ReportEngine.App.Views.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <DockPanel>

        <!--  Верхняя панель  -->
        <Border
            Padding="8"
            Background="{DynamicResource SecondaryColor}"
            DockPanel.Dock="Top">

            <StackPanel Orientation="Horizontal">

                <Button
                    Width="120"
                    Margin="4"
                    Command="{Binding OpenCommand}"
                    Content="📂 Открыть" />

                <Button
                    Width="120"
                    Margin="4"
                    Command="{Binding SaveCommand}"
                    Content="💾 Сохранить" />

            </StackPanel>
        </Border>

        <!--  Нижний статусбар  -->
        <StatusBar DockPanel.Dock="Bottom">
            <TextBlock Text="Готово" />
        </StatusBar>

        <!--  Основная область  -->
        <Grid Background="{DynamicResource PrimaryColor}">
            <Spreadsheet:SfSpreadsheet
                x:Name="MainSreadSheet"
                Margin="5"
                Background="{DynamicResource PrimaryColor}"
                BorderBrush="{DynamicResource SecondaryColor}" />
        </Grid>

    </DockPanel>
</UserControl>