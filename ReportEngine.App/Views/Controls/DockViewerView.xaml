<UserControl
    x:Class="ReportEngine.App.Views.Controls.DockViewerView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Spreadsheet="clr-namespace:Syncfusion.UI.Xaml.Spreadsheet;assembly=Syncfusion.SfSpreadsheet.WPF"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ReportEngine.App.Views.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Spreadsheet:SfSpreadsheet x:Name="MainSreadSheet" Grid.Row="0" />

        <StackPanel Grid.Row="1" Orientation="Horizontal">

            <Button
                Height="40"
                Margin="5"
                Click="OpenButton_Click"
                Content="Открыть"
                FontSize="16" />
            <Button
                Height="40"
                Margin="5"
                Click="SaveButton_Click"
                Content="Сохранить"
                FontSize="16" />
        </StackPanel>
    </Grid>
</UserControl>