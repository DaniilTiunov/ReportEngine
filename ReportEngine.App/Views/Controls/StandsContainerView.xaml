<UserControl
    x:Class="ReportEngine.App.Views.Controls.StandsContainerView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch"
    d:DesignHeight="700"
    d:DesignWidth="800"
    Background="{DynamicResource PrimaryColor}"
    FontSize="16"
    Foreground="{DynamicResource PrimaryForeground}"
    mc:Ignorable="d">

    <UserControl.InputBindings>
        <KeyBinding
            Key="F5"
            Command="{Binding ProjectCommandProvider.RefreshBatchesCommand}"
            CommandParameter="{x:Null}" />
    </UserControl.InputBindings>


    <ScrollViewer
            Margin="10"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
        Width="Auto">
        <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                
            </Grid.ColumnDefinitions>

            <GroupBox
                    Grid.Row="0"
                    Grid.Column="0"
                    Margin="5"
                    Padding="5"
                    Header="Партии упаковок проекта">
                <DockPanel LastChildFill="True">
                    <DataGrid
                            AutoGenerateColumns="False"
                            BeginningEdit="DataGrid_BeginningEdit"
                            CanUserAddRows="True"
                            CanUserDeleteRows="True"
                            EnableColumnVirtualization="False"
                            ItemsSource="{Binding CurrentProjectModel.ContainerBatchesInProject}"
                            MouseDoubleClick="DataGrid_MouseDoubleClick"
                            SelectedItem="{Binding CurrentProjectModel.SelectedContainerBatch}">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Command="{Binding ProjectCommandProvider.CreateContainerBatchCommand}"
                                              Header="Добавить партию" />
                                <Separator />
                                <MenuItem Command="{Binding ProjectCommandProvider.UpdateContainerCommand}"
                                              Header="Сохранить изменения" />
                                <Separator />
                                <MenuItem Command="{Binding ProjectCommandProvider.RefreshBatchesCommand}"
                                              Header="Обновить список" />
                                <Separator />
                                <MenuItem Command="{Binding ProjectCommandProvider.DeleteBatchCommand}"
                                              Header="Удалить партию" />
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn
                                    Width="Auto"
                                    Binding="{Binding BatchOrder}"
                                    Header="№" />
                            <DataGridTextColumn
                                    Width="*"
                                    Binding="{Binding Name}"
                                    Header="Имя" />
                            <DataGridTextColumn
                                    Width="Auto"
                                    Binding="{Binding ContainersCount}"
                                    Header="Количество тары" />
                            <DataGridTextColumn
                                    Width="Auto"
                                    Binding="{Binding StandsCount}"
                                    Header="Количество стендов" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </GroupBox>

            <GroupBox
                    Grid.Row="0"
                    Grid.Column="2"
                    MinHeight="300"
                    Margin="5"
                    Padding="5">
                <GroupBox.Header>
                    <TextBlock>
                            <Run Text="Партия упаковок №" />
                            <Run
                                FontSize="14"
                                FontWeight="Bold"
                                Text="{Binding CurrentProjectModel.SelectedContainerBatch.BatchOrder, TargetNullValue='(ошибка привязки)'}" />
                    </TextBlock>
                </GroupBox.Header>
                <DockPanel LastChildFill="True">
                    <DataGrid
                            BeginningEdit="DataGrid_BeginningEdit"
                            CanUserAddRows="True"
                            CanUserDeleteRows="True"
                            IsReadOnly="False"
                            ItemsSource="{Binding CurrentProjectModel.ContainerStandsInSelectedBatch}"
                            MouseDoubleClick="DataGrid_MouseDoubleClick"
                            SelectedItem="{Binding CurrentProjectModel.SelectedContainerStand}">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Command="{Binding ProjectCommandProvider.UpdateContainerCommand}"
                                              Header="Сохранить изменения" />
                                <Separator />
                                <MenuItem Command="{Binding ProjectCommandProvider.DeleteContainerCommand}"
                                              Header="Удалить упаковку" />
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn
                                    Width="*"
                                    Binding="{Binding Name}"
                                    Header="Тара" />
                            <DataGridTextColumn
                                    Width="Auto"
                                    Binding="{Binding StandsCount}"
                                    Header="Количество стендов" />
                            <DataGridTextColumn
                                    Width="Auto"
                                    Binding="{Binding StandsWeight}"
                                    Header="Масса стендов" />
                            <DataGridTextColumn
                                    Width="Auto"
                                    Binding="{Binding ContainerWeight}"
                                    Header="Общая масса" />
                            <DataGridTextColumn
                                    Width="Auto"
                                    Binding="{Binding ContainerCost}"
                                    Header="Стоимость" />
                            <DataGridTemplateColumn Header="Выбрать">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button
                                                Margin="2,0,2,0"
                                                Padding="5,0,5,0"
                                                Command="{Binding DataContext.ProjectCommandProvider.OpenAllSortamentsDialogCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Content="Выбрать" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </GroupBox>

            <StackPanel
                    Grid.Row="1"
                    Grid.Column="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                <Button
                        Width="120"
                        Margin="5"
                        Command="{Binding ProjectCommandProvider.AddStandToContainerCommand}"
                        Content="&lt;&lt;&lt; Добавить" />

                <Button
                        Width="120"
                        Margin="5"
                        Command="{Binding ProjectCommandProvider.RemoveStandFromContainerCommand}"
                        Content="Удалить &gt;&gt;&gt;" />
            </StackPanel>

            <GroupBox
                    Grid.Row="1"
                    Grid.Column="2"
                    Margin="5"
                    Padding="5"
                    Header="Стенды проекта">
                <DataGrid
                        AutoGenerateColumns="False"
                        CanUserAddRows="False"
                        IsReadOnly="True"
                        ItemsSource="{Binding CurrentProjectModel.Stands}"
                        SelectedItem="{Binding CurrentProjectModel.SelectedStandInProject}">
                    <DataGrid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Command="{Binding ProjectCommandProvider.AddStandToContainerCommand}"
                                          Header="Добавить выбранный стенд в контейнер" />
                        </ContextMenu>
                    </DataGrid.ContextMenu>

                    <DataGrid.Columns>
                        <DataGridTextColumn Binding="{Binding KKSCode}" Header="KKS" />
                        <DataGridTextColumn
                                Width="140"
                                Binding="{Binding SerialNumber}"
                                Header="Серийный номер" />
                        <DataGridTextColumn Binding="{Binding Weight}" Header="KKS" />
                        <DataGridTextColumn
                                Width="80"
                                Binding="{Binding Width}"
                                Header="Ширина" />
                        <DataGridTextColumn
                                Width="80"
                                Binding="{Binding Weight}"
                                Header="Вес стенда" />
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>


            <GroupBox
                    Grid.Row="1"
                    MinHeight="50"
                    Margin="5"
                    Header="Стенды внутри тары">
                <DataGrid
                        Margin="5"
                        AutoGenerateColumns="False"
                        IsReadOnly="True"
                        ItemsSource="{Binding CurrentProjectModel.StandsInSelectedContainer}"
                        SelectedItem="{Binding CurrentProjectModel.SelectedStandInContainer}">
                    <DataGrid.Columns>
                        <DataGridTextColumn
                                Width="*"
                                Binding="{Binding KKSCode}"
                                Header="KKS" />
                        <DataGridTextColumn
                                Width="200"
                                Binding="{Binding SerialNumber}"
                                Header="Серийный номер" />
                        <DataGridTextColumn
                                Width="100"
                                Binding="{Binding Width}"
                                Header="Ширина" />
                        <DataGridTextColumn
                                Width="100"
                                Binding="{Binding Weight}"
                                Header="Вес стенда" />
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>
        </Grid>
    </ScrollViewer>
</UserControl>