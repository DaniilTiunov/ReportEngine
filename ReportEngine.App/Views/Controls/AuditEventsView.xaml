<UserControl
    FontSize="16"
    d:DesignHeight="300"
    d:DesignWidth="300"
    mc:Ignorable="d"
    x:Class="ReportEngine.App.Views.Controls.AuditEventsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:converters="clr-namespace:ReportEngine.App.Display"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ReportEngine.App.Views.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <converters:UtcToLocalConverter x:Key="UtcToLocalConverter" />
    </UserControl.Resources>

    <DockPanel Margin="10">

        <!--  Фильтры  -->
        <StackPanel
            DockPanel.Dock="Top"
            Margin="10,0,0,10"
            Orientation="Horizontal">
            <TextBlock
                Margin="10,0,5,0"
                Text="С:"
                VerticalAlignment="Center" />
            <DatePicker SelectedDate="{Binding FilterFrom}" Width="120" />
            <TextBlock
                Margin="10,0,5,0"
                Text="По:"
                VerticalAlignment="Center" />
            <DatePicker SelectedDate="{Binding FilterTo}" Width="120" />
            <Button
                Command="{Binding LoadAllEventsCommand}"
                Content="Загрузить все"
                Margin="10,0,0,0" />
            <Button
                Command="{Binding LoadFilteredEventsCommand}"
                Content="Загрузить с фильтром"
                Margin="10,0,0,0" />
        </StackPanel>

        <!--  Таблица событий  -->
        <DataGrid
            AutoGenerateColumns="False"
            CanUserAddRows="False"
            DockPanel.Dock="Bottom"
            IsReadOnly="True"
            ItemsSource="{Binding AllEvents}">
            <DataGrid.Columns>
                <DataGridTextColumn
                    Binding="{Binding Timestamp, Converter={StaticResource UtcToLocalConverter}, StringFormat=dd.MM.yyyy HH:mm:ss}"
                    Header="Дата/Время"
                    Width="200" />
                <DataGridTextColumn
                    Binding="{Binding UserSystemName}"
                    Header="Пользователь"
                    Width="300" />
                <DataGridTextColumn
                    Binding="{Binding Action}"
                    Header="Действие"
                    Width="*" />
                <DataGridTextColumn
                    Binding="{Binding Details}"
                    Header="Детали"
                    Width="*" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
