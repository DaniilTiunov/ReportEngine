<Window
    Background="{DynamicResource PrimaryColor}"
    FontFamily="Bahnschrift"
    Foreground="{DynamicResource PrimaryForeground}"
    ResizeMode="CanResize"
    Title="Стенды КИПиА"
    WindowStartupLocation="CenterScreen"
    WindowState="Normal"
    WindowStyle="None"
    mc:Ignorable="d"
    x:Class="ReportEngine.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:converters="clr-namespace:ReportEngine.App.Display"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <WindowChrome.WindowChrome>
        <WindowChrome
            CaptionHeight="0"
            CornerRadius="0"
            GlassFrameThickness="0" />
    </WindowChrome.WindowChrome>

    <Window.InputBindings>
        <KeyBinding
            Command="{Binding MainWindowCommandProvider.ShowAllProjectsCommand}"
            CommandParameter="{x:Null}"
            Key="F5" />
    </Window.InputBindings>

    <Window.Resources>
        <ResourceDictionary>
            <Image Source="/Resources/Images/refresh-button.png" x:Key="refresh-button.png" />
            <converters:AdminVisibilityConverter x:Key="AdminVisibilityConverter" />
            <converters:TranslateUserRole x:Key="TranslateUserRole" />
        </ResourceDictionary>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard>
                <Storyboard>
                    <DoubleAnimation
                        Duration="0:0:0.5"
                        From="0.0"
                        Storyboard.TargetProperty="Opacity"
                        To="1.0" />
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </Window.Triggers>

    <Border Style="{DynamicResource WindowBorder}">
        <DockPanel>
            <!--  Верхняя панель заголовка  -->
            <Border
                Background="#2D2D30"
                DockPanel.Dock="Top"
                Height="34"
                MouseLeftButtonDown="Window_MouseLeftButtonDown"
                x:Name="MainWindowControlTitle">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel
                        Margin="10,0,0,0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                        <Image
                            Height="18"
                            Margin="0,0,8,0"
                            Source="/Resources/Icons/estimate_cost_icon_213382.ico"
                            Width="18" />
                        <TextBlock
                            FontSize="14"
                            Foreground="White"
                            Text="{Binding Title, RelativeSource={RelativeSource AncestorType=Window}}"
                            VerticalAlignment="Center" />
                    </StackPanel>

                    <StackPanel
                        Grid.Column="1"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                        <Button
                            Click="MinimizeButton_Click"
                            FontSize="16"
                            Height="30"
                            ToolTip="Свернуть"
                            Width="40"
                            x:Name="MinimizeButton">
                            ─
                        </Button>
                        <Button
                            Click="MaxRestoreButton_Click"
                            FontSize="16"
                            Height="30"
                            Margin="10,0,0,0"
                            ToolTip="Развернуть"
                            Width="40"
                            x:Name="MaxRestoreButton">
                            ▢
                        </Button>
                        <Button
                            Click="CloseButton_Click"
                            FontSize="16"
                            Height="30"
                            Margin="10,0,10,0"
                            ToolTip="Закрыть"
                            Width="40"
                            x:Name="CloseButton">
                            ✕
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!--  Меню  -->
            <Menu
                DockPanel.Dock="Top"
                FontFamily="Bahnschrift"
                FontSize="14"
                Height="25">

                <Menu.ItemsPanel>
                    <ItemsPanelTemplate>
                        <DockPanel HorizontalAlignment="Stretch" />
                    </ItemsPanelTemplate>
                </Menu.ItemsPanel>

                <!--  Ваше меню без изменений  -->
                <MenuItem Header="Проект">
                    <MenuItem Command="{Binding MainWindowCommandProvider.OpenTreeViewCommand}" Header="Создать новый проект" />
                    <Separator />
                    <MenuItem Command="{Binding MainWindowCommandProvider.OpenMainWindowCommand}" Header="На главный экран" />
                </MenuItem>

                <MenuItem Header="Настройки">
                    <MenuItem Command="{Binding MainWindowCommandProvider.OpenCalculationParametersCommand}" Header="Параметры расчета" />
                    <Separator />
                    <MenuItem Command="{Binding MainWindowCommandProvider.OpenSettingsWindow}" Header="Настройки приложения" />
                    <Separator />
                    <MenuItem Header="База данных">
                        <MenuItem Command="{Binding MainWindowCommandProvider.SetOnlineDbCommand}" Header="Удалённый сервер" />
                        <MenuItem Command="{Binding MainWindowCommandProvider.SetOfflineDbCommand}" Header="Локально" />
                    </MenuItem>
                </MenuItem>

                <MenuItem Header="Вид" Tag="ThemeItemChanger">
                    <MenuItem
                        Click="StandardTheme"
                        Header="Светлая тема"
                        Tag="Standart" />
                    <Separator />
                    <MenuItem
                        Click="ChangeDarkTheme"
                        Header="Тёмная тема"
                        Tag="Dark" />
                    <Separator />
                    <MenuItem
                        Click="MangoParadiseTheme"
                        Header="Манговый рай"
                        Tag="Mango" />
                    <Separator />
                    <MenuItem
                        Click="BubbleGumTheme"
                        Header="Жвачка"
                        Tag="Bubble" />
                </MenuItem>

                <MenuItem Header="Контакты">
                    <MenuItem Command="{Binding MainWindowCommandProvider.OpenAllUsersCommand}" Header="Сотрудники" />
                    <Separator />
                    <MenuItem Command="{Binding MainWindowCommandProvider.OpenAllCompaniesCommand}" Header="Заказчики" />
                    <Separator />
                    <MenuItem Command="{Binding MainWindowCommandProvider.OpenAllSubjectsCommand}" Header="Объекты" />
                </MenuItem>

                <MenuItem Header="Комплектующие">
                    <!--  Ваши подменю  -->
                    <MenuItem Command="{Binding MainWindowCommandProvider.OpenAllObvyazkiCommand}" Header="Обвязки" />
                    <Separator />
                    <MenuItem Header="Сортамент труб">
                        <MenuItem Command="{Binding GenericEquipCommandProvider.OpenHeaterPipeCommand}" Header="Жаропрочная сталь" />
                        <MenuItem Command="{Binding GenericEquipCommandProvider.OpenStainlessPipeCommand}" Header="Нержавеющая сталь" />
                        <MenuItem Command="{Binding GenericEquipCommandProvider.OpenCarbonPipeCommand}" Header="Углеродистая сталь" />
                    </MenuItem>
                    <MenuItem Header="Запорные арматуры">
                        <MenuItem Command="{Binding GenericEquipCommandProvider.OpenHeaterArmatureCommand}" Header="Жаропрочная сталь" />
                        <MenuItem Command="{Binding GenericEquipCommandProvider.OpenStainlessArmatureCommand}" Header="Нержавеющая сталь" />
                        <MenuItem Command="{Binding GenericEquipCommandProvider.OpenCarbonArmatureCommand}" Header="Углеродистая сталь" />
                    </MenuItem>
                    <MenuItem Header="Тройники и КМЧ">
                        <MenuItem Command="{Binding GenericEquipCommandProvider.OpenHeaterSocketsCommand}" Header="Жаропрочная сталь" />
                        <MenuItem Command="{Binding GenericEquipCommandProvider.OpenStainlessSocketsCommand}" Header="Нержавеющая сталь" />
                        <MenuItem Command="{Binding GenericEquipCommandProvider.OpenCarbonSocketsCommand}" Header="Углеродистая сталь" />
                    </MenuItem>
                    <Separator />
                    <MenuItem Command="{Binding GenericEquipCommandProvider.OpenDrainageCommand}" Header="Дренаж" />
                    <Separator />
                    <MenuItem Header="Рамные комплектующие">
                        <MenuItem Command="{Binding GenericEquipCommandProvider.OpenFrameDetailsCommand}" Header="Детали рамы" />
                        <MenuItem Command="{Binding GenericEquipCommandProvider.OpenPillarEquipCommand}" Header="Комплектующие для стойки" />
                        <MenuItem Command="{Binding GenericEquipCommandProvider.OpenFrameRollCommand}" Header="Прокат" />
                    </MenuItem>
                    <Separator />
                    <MenuItem Header="Кронштейны">
                        <MenuItem Command="{Binding GenericEquipCommandProvider.OpenBoxesBracesommand}" Header="Крепление клеммных коробок" />
                        <MenuItem Command="{Binding GenericEquipCommandProvider.OpenDrainageBracesCommand}" Header="Крепление дренажа" />
                        <MenuItem Command="{Binding GenericEquipCommandProvider.OpenSensorsBracesCommand}" Header="Крепление датчиков" />
                    </MenuItem>
                    <Separator />
                    <MenuItem Header="Электрические компоненты">
                        <MenuItem Command="{Binding GenericEquipCommandProvider.OpenCabelProductionCommand}" Header="Кабельная продукция" />
                        <MenuItem Command="{Binding GenericEquipCommandProvider.OpenCabelInputCommand}" Header="Кабельные вводы" />
                        <MenuItem Command="{Binding GenericEquipCommandProvider.OpenCabelBoxeCommand}" Header="Клеммные коробки" />
                        <MenuItem Command="{Binding GenericEquipCommandProvider.OpenHeaterCommand}" Header="Обогрев" />
                        <MenuItem Command="{Binding GenericEquipCommandProvider.OpenCabelProtectionCommand}" Header="Средства прокладки и защиты кабеля" />
                    </MenuItem>
                    <Separator />
                    <MenuItem Command="{Binding GenericEquipCommandProvider.OpenOthersCommand}" Header="Прочие" />
                    <Separator />
                    <MenuItem Command="{Binding GenericEquipCommandProvider.OpenConteinersCommand}" Header="Тара" />
                    <Separator />
                    <MenuItem Command="{Binding MainWindowCommandProvider.OpenAllSortamentsCommand}" Header="Весь сортамент" />
                </MenuItem>

                <MenuItem Header="Формирование комплектующих">
                    <MenuItem Command="{Binding MainWindowCommandProvider.OpenFormedFramesCommand}" Header="Создание и редактирование рам" />
                    <Separator />
                    <MenuItem Command="{Binding MainWindowCommandProvider.OpenAllDrainagesCommand}" Header="Дренажи" />
                </MenuItem>

                <MenuItem Command="{Binding MainWindowCommandProvider.OpenAllStandsCommand}" Header="Стенды" />

                <MenuItem Header="Инструменты">
                    <MenuItem Click="OpenLauncher" Header="Открыть лаунчер" />
                    <Separator />
                    <MenuItem Click="ShowCalculator" Header="Калькулятор" />
                    <Separator />
                    <MenuItem Click="ShowNotepad" Header="Блокнот" />
                </MenuItem>

                <MenuItem Header="Справка">
                    <MenuItem Click="ShowAboutProgram" Header="О программе" />
                    <Separator />
                    <MenuItem Click="OpenHelp" Header="Помощь" />
                    <Separator />
                    <MenuItem Click="AutoUpdate" Header="Обновить приложение" />
                    <Separator />
                    <MenuItem Click="ShowUpdateIndo" Header="История обновлений" />
                </MenuItem>

                <MenuItem Command="{Binding MainWindowCommandProvider.OpenAuthWindowCommand}" Header="Авторизация" />
                <MenuItem Command="{Binding MainWindowCommandProvider.OpenAuditContentCommand}" Header="Аудит" />

                <MenuItem
                    Click="OpenAssistant_Click"
                    DockPanel.Dock="Right"
                    Header="ИИ помощник" />

                <MenuItem
                    Click="OpenLogger_Click"
                    Header="Логгер"
                    HorizontalAlignment="Right"
                    Width="80" />
            </Menu>

            <!--  StatusBar  -->
            <StatusBar
                DockPanel.Dock="Bottom"
                FontFamily="Bahnschrift"
                Height="30">
                <StatusBarItem>
                    <TextBlock
                        FontSize="14"
                        Margin="5,0,0,0"
                        Text="Текущий пользователь:" />
                </StatusBarItem>
                <StatusBarItem>
                    <TextBlock
                        FontSize="14"
                        FontWeight="Bold"
                        Margin="5,0,0,0"
                        Text="{Binding CurrentUserLogin}" />
                </StatusBarItem>
                <StatusBarItem>
                    <TextBlock
                        FontSize="14"
                        Margin="5,0,0,0"
                        Text="Права доступа:" />
                </StatusBarItem>
                <StatusBarItem>
                    <TextBlock
                        FontSize="14"
                        FontWeight="Bold"
                        Margin="5,0,0,0"
                        Text="{Binding CurrentUser.SystemRole, Converter={StaticResource TranslateUserRole}}" />
                </StatusBarItem>

                <StatusBarItem HorizontalAlignment="Right">
                    <TextBlock
                        FontSize="14"
                        Margin="5,0,0,0"
                        Text="Режим работы базы данных:" />
                </StatusBarItem>
                <StatusBarItem HorizontalAlignment="Right">
                    <TextBlock
                        FontSize="14"
                        FontWeight="Bold"
                        Margin="5,0,0,0"
                        Text="{Binding DatabaseMode}" />
                </StatusBarItem>

                <StatusBarItem HorizontalAlignment="Stretch">
                    <Separator Visibility="Hidden" />
                </StatusBarItem>

                <StatusBarItem HorizontalAlignment="Right">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock FontSize="14" Text="Статус подключения к серверу:" />
                        <TextBlock
                            FontSize="14"
                            Margin="5,0,0,0"
                            Text="{Binding MainWindowModel.ConnectionStatusMessage}"
                            Width="191" />
                        <Button
                            BorderThickness="0"
                            Command="{Binding MainWindowCommandProvider.ChekDbConnectionCommand}"
                            Content="{StaticResource refresh-button.png}"
                            Height="24"
                            Margin="0,0,0,0" />
                    </StackPanel>
                </StatusBarItem>
            </StatusBar>

            <Grid>
                <!--  Основной контент  -->
                <ContentControl
                    HorizontalContentAlignment="Stretch"
                    VerticalContentAlignment="Stretch"
                    x:Name="MainContentControl">

                    <Grid x:Name="MainGrid">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="35" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal">
                            <TextBlock
                                FontSize="16"
                                Margin="5,5,10,10"
                                Text="Поиск: " />
                            <TextBox
                                Background="{DynamicResource SecondaryColor}"
                                FontSize="16"
                                Height="23"
                                Margin="0,5,0,5"
                                Text=""
                                TextChanged="SearchTextBox_TextChanged"
                                Width="500"
                                x:Name="SearchTextBox" />
                        </StackPanel>

                        <DataGrid
                            AutoGenerateColumns="False"
                            Grid.Row="1"
                            IsReadOnly="True"
                            Margin="0,5,0,5"
                            MouseDoubleClick="MainDataGrid_OnMouseDoubleClick"
                            SelectedItem="{Binding MainWindowModel.SelectedProject}"
                            SelectionUnit="FullRow"
                            x:Name="MainDataGrid">
                            <DataGrid.Columns>
                                <DataGridTextColumn
                                    Binding="{Binding Number}"
                                    Header="№п/п"
                                    SortMemberPath="Number"
                                    Width="*" />
                                <DataGridTextColumn
                                    Binding="{Binding Company}"
                                    Header="Заказчик"
                                    Width="*" />
                                <DataGridTextColumn
                                    Binding="{Binding Object}"
                                    Header="Объект"
                                    Width="*" />
                                <DataGridTextColumn
                                    Binding="{Binding StandCount}"
                                    Header="Кол-во стендов"
                                    Width="*" />
                                <DataGridTextColumn
                                    Binding="{Binding Status}"
                                    Header="Статус"
                                    Width="*" />
                                <DataGridTextColumn
                                    Binding="{Binding StartDate, StringFormat={}{0:dd-MM-yy}}"
                                    Header="Старт проекта"
                                    Width="*" />
                                <DataGridTextColumn
                                    Binding="{Binding OutOfProduction, StringFormat={}{0:dd-MM-yy}}"
                                    Header="Выход из производства"
                                    Width="*" />
                                <DataGridTextColumn
                                    Binding="{Binding EndDate, StringFormat={}{0:dd-MM-yy}}"
                                    Header="Дата окончания договора"
                                    Width="*" />
                                <DataGridTextColumn
                                    Binding="{Binding OrderCustomer}"
                                    Header="Заказ покупателя"
                                    Width="*" />
                                <DataGridTextColumn
                                    Binding="{Binding RequestProduction}"
                                    Header="Заявка на производство"
                                    Width="*" />
                                <DataGridTextColumn
                                    Binding="{Binding HumanCost}"
                                    Header="Трудозатраты"
                                    Width="*" />
                                <DataGridTextColumn
                                    Binding="{Binding Manager}"
                                    Header="Руководитель"
                                    Width="*" />
                                <DataGridTextColumn
                                    Binding="{Binding MarkPlus}"
                                    Header="Маркировка +"
                                    Width="*" />
                                <DataGridTextColumn
                                    Binding="{Binding MarkMinus}"
                                    Header="Маркировка -"
                                    Width="*" />
                            </DataGrid.Columns>
                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Command="{Binding MainWindowCommandProvider.EditProjectCommand}" Header="Редактировать проект" />
                                    <MenuItem Command="{Binding MainWindowCommandProvider.CopySelectedProjectCommand}" Header="Копировать проект" />
                                    <MenuItem Command="{Binding MainWindowCommandProvider.RecalculateProjectCommand}" Header="Переформировать" />
                                    <MenuItem
                                        Command="{Binding MainWindowCommandProvider.DeleteSelectedProjectCommand}"
                                        Header="Удалить проект"
                                        Visibility="{Binding CurrentUser.SystemRole, Converter={StaticResource AdminVisibilityConverter}}" />
                                    <Separator />
                                    <MenuItem Command="{Binding MainWindowCommandProvider.ShowAllProjectsCommand}" Header="Обновить список проектов" />
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                        </DataGrid>
                    </Grid>
                </ContentControl>

                <!--  AI панель - будет открываться справа  -->
                <Border
                    Background="{DynamicResource SecondaryColor}"
                    BorderBrush="{DynamicResource BorderMediumColor}"
                    BorderThickness="3"
                    HorizontalAlignment="Right"
                    Panel.ZIndex="999"
                    VerticalAlignment="Stretch"
                    Visibility="Collapsed"
                    Width="450"
                    x:Name="AiAssistantContainer">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="35" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!--  Заголовок  -->
                        <Border Background="{DynamicResource SecondaryColor}" Grid.Row="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    FontSize="15"
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource PrimaryForeground}"
                                    Margin="10,0,0,0"
                                    Text="ИИ помощник"
                                    VerticalAlignment="Center" />

                                <Button
                                    Click="CloseAiAssistant_Click"
                                    Content="✕"
                                    FontSize="12"
                                    Grid.Column="1"
                                    Height="30"
                                    Width="30" />
                            </Grid>
                        </Border>

                        <!--  Контент  -->
                        <ContentControl Grid.Row="1" x:Name="AiAssistantHost" />
                    </Grid>
                </Border>

                <!--  Окно для логирования  -->
                <Border
                    Background="{DynamicResource SecondaryColor}"
                    BorderBrush="{DynamicResource BorderMediumColor}"
                    BorderThickness="3"
                    CornerRadius="3"
                    Height="500"
                    HorizontalAlignment="Stretch"
                    MaxHeight="800"
                    MinHeight="150"
                    Panel.ZIndex="998"
                    VerticalAlignment="Bottom"
                    Visibility="Collapsed"
                    x:Name="LogContainer">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="35" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!--  Заголовок  -->
                        <Border
                            Background="{DynamicResource BorderMediumColor}"
                            CornerRadius="3"
                            Grid.Row="0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock
                                    FontSize="15"
                                    Foreground="{DynamicResource PrimaryForeground}"
                                    Margin="10,0,0,0"
                                    Text="📋 Логи"
                                    VerticalAlignment="Center" />

                            </Grid>
                        </Border>

                        <!--  Контент логов  -->
                        <ContentControl Grid.Row="1" x:Name="LogHost" />
                    </Grid>
                </Border>
            </Grid>
        </DockPanel>
    </Border>
</Window>